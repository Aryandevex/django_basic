# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Python files
*.py text eol=lf

# HTML/CSS/JS
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.cfg  text eol=lf

# Binary files – no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
